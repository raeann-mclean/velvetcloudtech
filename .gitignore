# ============================================================
# Velvet Cloud Tech — .gitignore
# ============================================================

# ----- Secrets & environment variables -----
.env
.env.*
.env.local
.env.development
.env.production
*.pem
*.key
*.p12
*.pfx
secrets.json
secrets.yml
secrets.yaml
config/secrets.*

# ----- Node / npm -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.npm/
.pnpm-store/

# ----- Build output -----
dist/
build/
out/
.cache/
.parcel-cache/
.vite/

# ----- macOS -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# ----- Windows -----
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ----- Linux -----
*~

# ----- Editors & IDEs -----
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ----- Logs -----
logs/
*.log

# ----- Misc -----
/README.md
